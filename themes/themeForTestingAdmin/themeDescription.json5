// This file follows the JSON5 standard - comments and trailing commas are supported
{
  "name": "themeForTestingAdmin",
  "version": "1.0.0",
  "description": "Tema admin dedicato al testing automatizzato. Basato su defaultAdminTheme per garantire il corretto avvio del pannello di amministrazione nei test.",
  "author": "Italo Paesano",
  "email": "italopaesano@protonmail.com",
  "license": "ISC",
  "tags": ["admin", "testing", "bootstrap", "automated-tests"],
  "supportedHooks": [
    "head",
    "header",
    "nav",
    "main",
    "body",
    "aside",
    "footer",
    "script"
  ],
  "features": {
    "themeResources": true,
    "pluginCustomization": true,
    "responsive": true,
    "darkMode": false
  }
}
