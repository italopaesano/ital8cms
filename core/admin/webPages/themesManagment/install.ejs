<!-- PAGINA INSTALLAZIONE TEMA DA REPO GIT REMOTO -->
<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>

<script>
    const apiPrefix = '<%= passData.apiPrefix %>';
    const adminPrefix = '<%= passData.adminPrefix %>';
</script>

<%
  passData.pageTitle = 'Installa Tema da Git';
  passData.pageIcon = 'bi bi-cloud-download';
%>

<div class="container mt-4">

  <div class="mb-3">
    <a href="/<%= passData.adminPrefix %>/themesManagment/index.ejs" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Torna alla lista temi
    </a>
  </div>

  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0"><i class="bi bi-cloud-download"></i> Installa un nuovo tema da repository Git</h5>
    </div>
    <div class="card-body">
      <div class="alert alert-info small mb-3">
        <strong>Convenzione obbligatoria:</strong> il repository deve avere un nome che inizia con
        <code>ital8cms-theme-</code>. Quanto segue diventa il nome del tema (convertito in camelCase) e
        deve combaciare con il campo <code>name</code> in <code>themeDescription.json5</code>.<br>
        Il tipo di tema (public o admin) è dichiarato esclusivamente dal campo
        <code>isAdminTheme</code> in <code>themeConfig.json5</code>: il nome del repo non distingue
        fra i due casi.
        <br><br>
        Esempi:
        <ul class="mb-0">
          <li><code>https://github.com/utente/ital8cms-theme-mySite.git</code> &rarr; tema <code>mySite</code></li>
          <li><code>https://github.com/utente/ital8cms-theme-my-cool-site.git</code> &rarr; tema <code>myCoolSite</code></li>
          <li><code>git@github.com:utente/ital8cms-theme-adminDashboard.git</code> &rarr; tema <code>adminDashboard</code> (SSH)</li>
        </ul>
      </div>

      <div class="alert alert-secondary small mb-3">
        <h6 class="alert-heading"><i class="bi bi-shield-lock"></i> Repository privati e accesso SSH</h6>
        <p class="mb-2">
          Sono supportati tre formati di URL:
        </p>
        <ul class="mb-2">
          <li><strong>HTTPS pubblico</strong> &mdash; <code>https://host/utente/repo.git</code></li>
          <li><strong>HTTPS con credenziali</strong> &mdash; <code>https://utente:token@host/utente/repo.git</code>
              (le credenziali le fornisci tu nell'URL)</li>
          <li><strong>SSH</strong> &mdash; <code>git@host:utente/repo.git</code> oppure
              <code>ssh://git@host/utente/repo.git</code></li>
        </ul>
        <p class="mb-2">
          <strong>Perché SSH è riservato al ruolo <code>root</code> (role 0):</strong> il clone via SSH
          non usa credenziali che fornisci nell'URL, ma la <strong>chiave SSH del server</strong>
          (quella in <code>~/.ssh/</code> dell'utente che esegue il processo Node). Significa che chi
          installa via SSH eredita <em>tutti gli accessi che la chiave del server ha</em> su GitHub/GitLab,
          anche a repository privati che l'installatore personalmente non potrebbe vedere. È un classico
          <em>confused deputy</em>: per questo l'opzione è concessa solo a chi è <code>root</code>, che ha
          già il pieno controllo della macchina.
        </p>
        <p class="mb-0">
          Gli admin (role 1) possono comunque installare da repository privati usando il formato
          <strong>HTTPS con credenziali</strong>: in quel caso l'autenticazione è la loro, non quella
          del server, quindi non c'è escalation. Il modello di sicurezza completo (audit, scenari
          multi-tenant, host whitelist) è tracciato nella sezione <em>Future Improvements</em> di
          <code>CLAUDE.md</code> e verrà approfondito.
        </p>
      </div>

      <form id="installForm">
        <div class="mb-3">
          <label for="repoUrl" class="form-label">URL del repository (HTTPS o SSH)</label>
          <input type="text" class="form-control" id="repoUrl" name="repoUrl" required
                 placeholder="https://github.com/utente/ital8cms-theme-mySite.git">
          <div class="form-text">
            HTTPS o SSH, deve terminare con <code>.git</code>.
            Gli URL SSH (<code>git@&hellip;</code> / <code>ssh://&hellip;</code>) richiedono il ruolo
            <strong>root</strong> (vedi nota sopra).
          </div>
        </div>

        <div class="mb-3">
          <label for="branchOrTag" class="form-label">Branch o Tag <span class="text-muted">(opzionale)</span></label>
          <input type="text" class="form-control" id="branchOrTag" name="branchOrTag"
                 placeholder="es. main, v1.2.0, develop">
          <div class="form-text">Se vuoto, viene usato il branch di default del repository.</div>
        </div>

        <div class="alert alert-warning small mb-3">
          <i class="bi bi-info-circle"></i>
          <strong>Nota:</strong> il tema viene installato come <strong>non pronto</strong>
          (<code>isInstalled: 0</code>). Per renderlo disponibile devi attivarlo
          manualmente dalla pagina di gestione temi; le modifiche all'attivazione richiedono il riavvio
          del server.
        </div>

        <button type="submit" class="btn btn-primary" id="submitBtn">
          <i class="bi bi-cloud-download"></i> Avvia installazione
        </button>
      </form>
    </div>
  </div>

  <!-- AREA DRY-RUN (visibile solo se debugMode >= 1 in ital8Config.json5) -->
  <div id="dryRunCard" class="card mb-4 border-info" style="display:none;">
    <div class="card-header bg-info bg-opacity-10">
      <h6 class="mb-0"><i class="bi bi-bug"></i> Debug: dry-run installazione</h6>
    </div>
    <div class="card-body">
      <p class="small mb-2">
        Esegue una finta installazione che emette eventi di progress realistici per
        circa 5 secondi, senza scaricare nulla né scrivere su disco. Utile per
        testare visivamente la progress bar e il flusso UI in isolamento. Disponibile
        solo con <code>debugMode: 1</code> in <code>ital8Config.json5</code>.
      </p>
      <button type="button" class="btn btn-sm btn-outline-info" id="dryRunBtn">
        <i class="bi bi-play-fill"></i> Esegui dry-run
      </button>
    </div>
  </div>

  <!-- AREA CONFERMA SOVRASCRITTURA -->
  <div id="overwriteCard" class="card mb-4 border-danger" style="display:none;">
    <div class="card-header bg-danger text-white">
      <h5 class="mb-0"><i class="bi bi-exclamation-octagon"></i> Tema già esistente: conferma sovrascrittura</h5>
    </div>
    <div class="card-body">
      <p class="mb-2">
        Esiste già una cartella <code id="overwriteThemeName"></code> in <code>themes/</code>.
        Procedere con la sovrascrittura <strong>cancellerà</strong> il tema attuale prima del clone.
      </p>
      <div id="overwriteExistingDetails" class="mb-3"></div>
      <div class="alert alert-warning small mb-3">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Operazione non recuperabile:</strong> i file del tema attuale verranno rimossi
        definitivamente. Se il clone successivo fallisce, il tema preesistente <strong>non</strong>
        verrà ripristinato.
      </div>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary" id="overwriteCancelBtn">
          <i class="bi bi-x-lg"></i> Annulla
        </button>
        <button type="button" class="btn btn-danger" id="overwriteConfirmBtn">
          <i class="bi bi-trash3"></i> Sovrascrivi (non recuperabile)
        </button>
      </div>
    </div>
  </div>

  <!-- AREA STATO -->
  <div id="statusCard" class="card mb-4" style="display:none;">
    <div class="card-header d-flex align-items-center">
      <h5 class="mb-0 me-2"><i class="bi bi-activity"></i> Stato installazione</h5>
      <span id="statusBadge" class="badge bg-secondary">pending</span>
    </div>
    <div class="card-body">
      <div id="progressBox" class="mb-3" style="display:none;">
        <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" style="height: 1.5rem;">
          <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated"
               style="width: 0%;">0%</div>
        </div>
        <div id="progressDetail" class="small text-muted mt-1"></div>
      </div>
      <div id="phasesList" class="mb-3"></div>
      <div id="warningsBox" class="alert alert-warning" style="display:none;">
        <strong><i class="bi bi-exclamation-triangle"></i> Avvertimenti:</strong>
        <ul id="warningsList" class="mb-0"></ul>
      </div>
      <div id="errorBox" class="alert alert-danger" style="display:none;">
        <strong><i class="bi bi-x-octagon"></i> Errore:</strong>
        <pre id="errorText" class="mb-0 mt-2" style="white-space:pre-wrap; word-break:break-word; font-size:0.9em;"></pre>
      </div>
      <div id="successBox" class="alert alert-success" style="display:none;">
        <strong><i class="bi bi-check-circle"></i> Installazione completata!</strong>
        <div id="successDetails" class="mt-2"></div>
      </div>
    </div>
  </div>

</div>

<script>
let pollingTimer = null;
// Conserva l'input del form per poterlo rinviare con confirmOverwrite=true.
let pendingInstallRequest = null;

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('installForm').addEventListener('submit', handleInstallSubmit);
  document.getElementById('overwriteConfirmBtn').addEventListener('click', handleOverwriteConfirm);
  document.getElementById('overwriteCancelBtn').addEventListener('click', handleOverwriteCancel);
  document.getElementById('dryRunBtn').addEventListener('click', handleDryRun);
  // Discovery del dry-run: visibile solo se il server lo abilita (debugMode >= 1).
  checkDryRunAvailability();
});

async function submitInstall(payload) {
  const submitBtn = document.getElementById('submitBtn');
  const overwriteBtn = document.getElementById('overwriteConfirmBtn');
  submitBtn.disabled = true;
  overwriteBtn.disabled = true;
  submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Avvio...';

  try {
    const r = await fetch(`/${apiPrefix}/admin/themes/install`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    });
    const j = await r.json();
    if (!j.success) {
      if (j.conflict) {
        showOverwritePrompt(j);
        return;
      }
      showStatusError(j.error || 'Errore sconosciuto.');
      return;
    }
    pendingInstallRequest = null;
    document.getElementById('overwriteCard').style.display = 'none';
    const statusCard = document.getElementById('statusCard');
    statusCard.style.display = 'block';
    statusCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    // Render immediato in stato pending: chiude il gap (0-400ms) tra il
    // click e il primo poll, durante il quale altrimenti il progressBox
    // resterebbe nascosto e l'utente penserebbe che non sia successo nulla.
    renderJob({ status: 'pending', progress: null, phases: [], warnings: [], result: null });
    startPolling(j.installId);
  } catch (e) {
    showStatusError(e.message);
  } finally {
    submitBtn.disabled = false;
    overwriteBtn.disabled = false;
    submitBtn.innerHTML = '<i class="bi bi-cloud-download"></i> Avvia installazione';
  }
}

async function handleInstallSubmit(ev) {
  ev.preventDefault();
  const repoUrl = document.getElementById('repoUrl').value.trim();
  const branchOrTag = document.getElementById('branchOrTag').value.trim();

  resetUi();
  pendingInstallRequest = { repoUrl, branchOrTag: branchOrTag || null };
  await submitInstall(pendingInstallRequest);
}

async function handleOverwriteConfirm() {
  if (!pendingInstallRequest) return;
  document.getElementById('overwriteCard').style.display = 'none';
  await submitInstall(Object.assign({}, pendingInstallRequest, { confirmOverwrite: true }));
}

function handleOverwriteCancel() {
  pendingInstallRequest = null;
  document.getElementById('overwriteCard').style.display = 'none';
}

function showOverwritePrompt(conflictResponse) {
  const themeName = conflictResponse.themeName || '?';
  const existing = conflictResponse.existingTheme || {};
  document.getElementById('overwriteThemeName').innerText = themeName;

  const detailsEl = document.getElementById('overwriteExistingDetails');
  if (existing.invalid) {
    detailsEl.innerHTML = `
      <div class="alert alert-secondary small mb-0">
        <i class="bi bi-question-circle"></i>
        La cartella esiste ma non sembra contenere un tema valido
        (${escapeHtml(existing.reason || 'motivo non specificato')}).
      </div>
    `;
  } else {
    const typeBadge = existing.isAdminTheme === true
      ? '<span class="badge bg-info text-dark">admin</span>'
      : existing.isAdminTheme === false
        ? '<span class="badge bg-light text-dark border">public</span>'
        : '<span class="badge bg-secondary">tipo sconosciuto</span>';
    detailsEl.innerHTML = `
      <ul class="list-unstyled mb-0">
        <li><strong>Nome dichiarato:</strong> ${escapeHtml(existing.name || themeName)} ${typeBadge}</li>
        ${existing.version ? `<li><strong>Versione:</strong> ${escapeHtml(existing.version)}</li>` : ''}
        ${existing.author ? `<li><strong>Autore:</strong> ${escapeHtml(existing.author)}</li>` : ''}
        ${existing.license ? `<li><strong>Licenza:</strong> ${escapeHtml(existing.license)}</li>` : ''}
      </ul>
    `;
  }
  document.getElementById('overwriteCard').style.display = 'block';
  document.getElementById('overwriteCard').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

async function checkDryRunAvailability() {
  try {
    const r = await fetch(`/${apiPrefix}/admin/themes/install/dryRunAvailable`);
    if (!r.ok) return;
    const j = await r.json();
    if (j && j.success && j.available) {
      document.getElementById('dryRunCard').style.display = 'block';
    }
  } catch (e) {
    // Silenzioso: l'assenza del bottone dry-run è un default sicuro.
  }
}

async function handleDryRun() {
  const btn = document.getElementById('dryRunBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Dry-run in corso...';

  // Reset UI come per un'installazione reale.
  document.getElementById('overwriteCard').style.display = 'none';
  resetUi();
  const statusCard = document.getElementById('statusCard');
  statusCard.style.display = 'block';
  statusCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  // Render immediato in stato pending (vedi commento in submitInstall).
  renderJob({ status: 'pending', progress: null, phases: [], warnings: [], result: null });

  try {
    const r = await fetch(`/${apiPrefix}/admin/themes/install/dryRun`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: '{}',
    });
    const j = await r.json();
    if (!j.success) {
      showStatusError(j.error || 'Errore durante l\'avvio del dry-run.');
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-play-fill"></i> Esegui dry-run';
      return;
    }
    startPolling(j.installId);
    // Riabilita il bottone quando il polling segnala la fine.
    const reEnable = setInterval(() => {
      if (!pollingTimer) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-play-fill"></i> Esegui dry-run';
        clearInterval(reEnable);
      }
    }, 500);
  } catch (e) {
    showStatusError('Errore di rete: ' + e.message);
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-play-fill"></i> Esegui dry-run';
  }
}

function startPolling(installId) {
  if (pollingTimer) clearInterval(pollingTimer);
  const tick = async () => {
    try {
      const r = await fetch(`/${apiPrefix}/admin/themes/install/${encodeURIComponent(installId)}/status`);
      const j = await r.json();
      if (!j.success) {
        showStatusError(j.error || 'Errore sconosciuto.');
        clearInterval(pollingTimer); pollingTimer = null;
        return;
      }
      renderJob(j.job);
      if (j.job.status === 'success' || j.job.status === 'failed') {
        clearInterval(pollingTimer); pollingTimer = null;
      }
    } catch (e) {
      console.error('Errore polling:', e);
    }
  };
  tick();
  // Polling rapido (400ms) per catturare gli stadi intermedi di un clone:
  // su connessioni veloci un clone reale può durare 1-2 secondi e con polling
  // a 1Hz si rischia di vedere solo la transizione finale a 100%. La cadenza
  // si ferma automaticamente al primo stato terminale (success/failed) quindi
  // il carico aggiuntivo è limitato alla durata effettiva dell'installazione.
  pollingTimer = setInterval(tick, 400);
}

function renderJob(job) {
  const badge = document.getElementById('statusBadge');
  badge.innerText = job.status;
  badge.className = 'badge ' + (
    job.status === 'success' ? 'bg-success' :
    job.status === 'failed'  ? 'bg-danger'  :
    job.status === 'running' ? 'bg-primary' : 'bg-secondary'
  );

  renderProgress(job);

  const phasesList = document.getElementById('phasesList');
  phasesList.innerHTML = job.phases.map(p => `
    <div class="d-flex align-items-start mb-1">
      <span class="me-2">${p.ok ? '<i class="bi bi-check-circle text-success"></i>' : '<i class="bi bi-x-circle text-danger"></i>'}</span>
      <div>
        <strong>${escapeHtml(p.name)}</strong>
        ${p.detail ? `<div class="small text-muted">${escapeHtml(p.detail)}</div>` : ''}
      </div>
    </div>
  `).join('');

  if (job.warnings && job.warnings.length > 0) {
    document.getElementById('warningsBox').style.display = 'block';
    document.getElementById('warningsList').innerHTML =
      job.warnings.map(w => `<li>${escapeHtml(w)}</li>`).join('');
  } else {
    document.getElementById('warningsBox').style.display = 'none';
  }

  if (job.status === 'failed') {
    document.getElementById('errorBox').style.display = 'block';
    document.getElementById('errorText').innerText = job.error || 'Errore sconosciuto.';
    document.getElementById('successBox').style.display = 'none';
    return;
  }

  if (job.status === 'success' && job.result) {
    const res = job.result;
    document.getElementById('successBox').style.display = 'block';
    const d = res.description || {};
    const adminBadge = res.isAdminTheme
      ? '<span class="badge bg-info text-dark">admin theme</span>'
      : '<span class="badge bg-light text-dark border">public theme</span>';
    const overwriteBadge = res.overwritten
      ? '<span class="badge bg-warning text-dark ms-1">sovrascrittura</span>'
      : '';
    document.getElementById('successDetails').innerHTML = `
      <ul class="list-unstyled mb-2">
        <li><strong>Tema:</strong> ${escapeHtml(res.themeName)} ${adminBadge}
            <span class="badge bg-secondary ms-1">disattivato</span>${overwriteBadge}</li>
        ${d.version ? `<li><strong>Versione:</strong> ${escapeHtml(d.version)}</li>` : ''}
        ${d.author ? `<li><strong>Autore:</strong> ${escapeHtml(d.author)}</li>` : ''}
        ${d.license ? `<li><strong>Licenza:</strong> ${escapeHtml(d.license)}</li>` : ''}
        <li><strong>Path:</strong> <code>${escapeHtml(res.themePath)}</code></li>
      </ul>
      <div class="alert alert-info small mb-0">
        <i class="bi bi-info-circle"></i>
        Il tema è stato installato ma resta <strong>disattivato</strong>. Vai alla
        <a href="/${adminPrefix}/themesManagment/index.ejs" class="alert-link">pagina di gestione temi</a>
        per attivarlo come tema pubblico o admin. L'attivazione richiede il riavvio del server
        per avere effetto.
      </div>
    `;
  }
}

const STAGE_LABELS = {
  receiving: 'Ricezione oggetti',
  resolving: 'Risoluzione delta',
  updatingFiles: 'Checkout file',
};

function renderProgress(job) {
  const box = document.getElementById('progressBox');
  const bar = document.getElementById('progressBar');
  const detail = document.getElementById('progressDetail');
  const p = job.progress;

  if (!p) {
    if (job.status === 'pending' || job.status === 'running') {
      // Nessun progress event ancora ricevuto ma l'install è in volo: mostra
      // uno stato indeterminato "Avvio..." con la barra a 100% striped/animated.
      // Cruciale per clone veloci (~1s) dove il primo poll può arrivare prima
      // che git abbia emesso eventi di progress: senza questo ramo l'utente
      // non vedrebbe MAI la barra.
      box.style.display = 'block';
      bar.style.width = '100%';
      bar.classList.add('progress-bar-animated');
      bar.innerText = 'Avvio...';
      bar.parentElement.setAttribute('aria-valuenow', '0');
      detail.innerHTML = '<em>Connessione al repository...</em>';
    } else if (job.status === 'success') {
      // Clone così veloce da non aver catturato alcun progress event: mostra
      // comunque la barra completa statica per dare feedback visivo.
      box.style.display = 'block';
      bar.style.width = '100%';
      bar.classList.remove('progress-bar-animated');
      bar.innerText = '100%';
      bar.parentElement.setAttribute('aria-valuenow', '100');
      detail.innerHTML = '<em>Clone completato (troppo veloce per il tracking degli eventi).</em>';
    } else {
      // failed senza progress: lascia parlare l'errorBox.
      box.style.display = 'none';
    }
    return;
  }

  box.style.display = 'block';
  const percent = Math.max(0, Math.min(100, Number(p.percent) || 0));
  bar.style.width = percent + '%';
  bar.innerText = percent + '%';
  bar.parentElement.setAttribute('aria-valuenow', String(percent));

  // Quando il job è terminato disattiva l'animazione striped della barra.
  if (job.status === 'success' || job.status === 'failed') {
    bar.classList.remove('progress-bar-animated');
  } else {
    bar.classList.add('progress-bar-animated');
  }

  const label = STAGE_LABELS[p.stage] || p.stage;
  const parts = [`<strong>${escapeHtml(label)}</strong>`,
                 `${p.current}/${p.total}`];
  if (p.bytes) parts.push(escapeHtml(p.bytes));
  if (p.rate) parts.push(escapeHtml(p.rate));
  detail.innerHTML = parts.join(' &middot; ');
}

function showStatusError(msg) {
  const statusCard = document.getElementById('statusCard');
  statusCard.style.display = 'block';
  statusCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  document.getElementById('statusBadge').innerText = 'failed';
  document.getElementById('statusBadge').className = 'badge bg-danger';
  document.getElementById('errorBox').style.display = 'block';
  document.getElementById('errorText').innerText = msg;
}

function resetUi() {
  if (pollingTimer) { clearInterval(pollingTimer); pollingTimer = null; }
  document.getElementById('statusCard').style.display = 'none';
  document.getElementById('overwriteCard').style.display = 'none';
  document.getElementById('progressBox').style.display = 'none';
  const bar = document.getElementById('progressBar');
  bar.style.width = '0%';
  bar.innerText = '0%';
  bar.classList.add('progress-bar-animated');
  document.getElementById('progressDetail').innerHTML = '';
  document.getElementById('phasesList').innerHTML = '';
  document.getElementById('warningsBox').style.display = 'none';
  document.getElementById('errorBox').style.display = 'none';
  document.getElementById('successBox').style.display = 'none';
}

function escapeHtml(s) {
  if (s === null || s === undefined) return '';
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
</script>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
