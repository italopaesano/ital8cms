// This file follows the JSON5 standard - comments and trailing commas are supported
{
  "version": "1.0.0",

  // Sezioni dell'interfaccia admin
  // Ogni sezione può essere:
  // - type: "plugin" → gestita da plugin (dinamica, con symlink)
  // - type: "hardcoded" → gestita direttamente da core/admin (statica)
  "sections": {
    // SEZIONI PLUGIN-BASED (dinamiche) - fornite da adminUsers plugin
    "usersManagment": {
      "type": "plugin",
      "plugin": "adminUsers",           // Nome del plugin che gestisce questa sezione
      "enabled": true,                  // Abilitata
      "required": true,                 // Se plugin manca, errore all'avvio
      "label": "Gestione Utenti",       // Testo mostrato nel menu
      "icon": "👥",                     // Icona (emoji, HTML, o classe CSS)
      "description": "Gestione utenti e permessi del sistema"
    },

    "rolesManagment": {
      "type": "plugin",
      "plugin": "adminUsers",           // Nome del plugin che gestisce questa sezione
      "enabled": true,                  // Abilitata
      "required": true,                 // Se plugin manca, errore all'avvio
      "label": "Gestione Ruoli Custom", // Testo mostrato nel menu
      "icon": "🏷️",                     // Icona (emoji, HTML, o classe CSS)
      "description": "Creazione e gestione ruoli personalizzati"
    },

    "adminAccessControl": {
      "type": "plugin",
      "plugin": "adminAccessControl",   // Nome del plugin che gestisce questa sezione
      "enabled": true,                  // Abilitata
      "required": false,                // Opzionale (il sistema funziona anche senza)
      "label": "Controllo Accessi",     // Testo mostrato nel menu
      "icon": "🔐",                     // Icona (emoji, HTML, o classe CSS)
      "description": "Gestione regole di accesso basate su ruoli per pagine e route"
    },

    // SEZIONI HARDCODED (statiche) - da implementare in futuro
    "pagesManagment": {
      "type": "hardcoded",
      "enabled": true,                  // Abilitata per test
      "label": "Creazione Pagine Web",
      "url": "/admin/pagesManagment/index.ejs",
      "icon": "📄"
    },

    "systemSettings": {
      "type": "hardcoded",
      "enabled": true,                  // Abilitata per test
      "label": "Impostazioni Sistema",
      "url": "/admin/systemSettings/index.ejs",
      "icon": "⚙️"
    },

    "pluginsManagment": {
      "type": "hardcoded",
      "enabled": true,                  // Abilitata per test
      "label": "Gestione Plugin",
      "url": "/admin/pluginsManagment/index.ejs",
      "icon": "🔌"
    },

    "themesManagment": {
      "type": "hardcoded",
      "enabled": true,                  // Abilitata per test
      "label": "Gestione Temi",
      "url": "/admin/themesManagment/index.ejs",
      "icon": "🎨"
    },

    "navbarsManagement": {
      "type": "plugin",
      "plugin": "adminBootstrapNavbar",
      "enabled": true,
      "required": false,
      "label": "Gestione bootstrapNavbar",
      "icon": "🧭",
      "description": "Creazione e gestione dei menu di navigazione bootstrapNavbar"
    },

    "seoManagement": {
      "type": "plugin",
      "plugin": "adminSeo",
      "enabled": true,
      "required": false,
      "label": "Gestione SEO",
      "icon": "🔍",
      "description": "Gestione impostazioni SEO, meta tag, sitemap e robots.txt"
    },

    "mediaManagement": {
      "type": "plugin",
      "plugin": "adminMedia",
      "enabled": true,
      "required": false,
      "label": "Media Management",
      "icon": "🗂️",
      "description": "Upload, browse and manage media files (images, video, audio)"
    },

    "analyticsManagement": {
      "type": "plugin",
      "plugin": "adminAnalytics",
      "enabled": true,
      "required": false,
      "label": "Analytics",
      "icon": "📊",
      "description": "Dashboard per il monitoraggio del traffico: visite, bot, referrer, log raw, export CSV/JSON"
    },

    "analyticsSettings": {
      "type": "plugin",
      "plugin": "adminAnalytics",
      "enabled": true,
      "required": false,
      "label": "Impostazioni Analytics",
      "icon": "⚙️",
      "description": "Configurazione del plugin analytics: GDPR, storage, performance, editor JSON5"
    }
  },

  // Ordinamento sezioni nel menu (dall'alto verso il basso)
  "menuOrder": [
    "usersManagment",
    "rolesManagment",
    "adminAccessControl",
    "pagesManagment",
    "systemSettings",
    "pluginsManagment",
    "themesManagment",
    "navbarsManagement",
    "seoManagement",
    "mediaManagement",
    "analyticsManagement",
    "analyticsSettings"
  ],

  // Servizi forniti da plugin (backend)
  // Un servizio è una funzionalità fornita da un plugin che può essere usata
  // da altri componenti del sistema (es. autenticazione, email, storage, etc.)
  "services": {
    "auth": {
      "plugin": "adminUsers",           // Plugin che fornisce autenticazione
      "required": true,                  // Servizio obbligatorio
    },
    "mailer": {
      "plugin": "mailer",               // Plugin che fornisce il servizio email
      "required": false,                // Opzionale: il sistema funziona senza email
    },
    // Altri servizi possono essere aggiunti in futuro:
    // "storage": { "plugin": "adminStorage", "required": false }
  },

  // Configurazione UI admin
  "ui": {
    "title": "Gestione Admin",
    "welcomeMessage": "Benvenuto nella gestione di Italo8CMS",
    "theme": "defaultAdminTheme",        // Riferimento a adminActiveTheme in ital8Config.json5
  }
}
