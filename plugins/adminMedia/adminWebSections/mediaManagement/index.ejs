<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>

<link rel="stylesheet" href="/<%= passData.adminPrefix %>/mediaManagement/media.css">

<div class="container-fluid mt-3" id="mediaApp">

  <!-- ── Top bar ──────────────────────────────────────────────────────────── -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-folder2-open me-2"></i>Media Management</h4>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-secondary btn-sm" id="btnNewFolder">
        <i class="bi bi-folder-plus"></i> New Folder
      </button>
      <button class="btn btn-primary btn-sm" id="btnUpload">
        <i class="bi bi-cloud-upload"></i> Upload Files
      </button>
      <input type="file" id="fileInput" multiple style="display:none">
    </div>
  </div>

  <!-- ── Warning / notification area ─────────────────────────────────────── -->
  <div id="warningArea"></div>

  <!-- ── Main layout: sidebar + content ──────────────────────────────────── -->
  <div class="row g-0">

    <!-- Sidebar: folder tree -->
    <div class="col-auto media-sidebar border-end pe-2 me-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted fw-semibold text-uppercase">Folders</small>
        <button class="btn btn-link btn-sm p-0 text-muted" id="btnRefreshTree" title="Refresh tree">
          <i class="bi bi-arrow-clockwise"></i>
        </button>
      </div>
      <div id="folderTree">
        <div class="text-muted small">Loading…</div>
      </div>
    </div>

    <!-- Content area -->
    <div class="col">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0" id="breadcrumb">
          <li class="breadcrumb-item active">/ (root)</li>
        </ol>
      </nav>

      <!-- Toolbar: filter + sort + view toggle + pagination info -->
      <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <!-- Filter tabs -->
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-secondary filter-btn active" data-filter="all">All</button>
          <button type="button" class="btn btn-outline-secondary filter-btn" data-filter="image"><i class="bi bi-image"></i> Images</button>
          <button type="button" class="btn btn-outline-secondary filter-btn" data-filter="video"><i class="bi bi-camera-video"></i> Video</button>
          <button type="button" class="btn btn-outline-secondary filter-btn" data-filter="audio"><i class="bi bi-music-note"></i> Audio</button>
        </div>

        <!-- Sort -->
        <select class="form-select form-select-sm" style="width:auto" id="sortSelect">
          <option value="name">Sort: Name</option>
          <option value="modified">Sort: Date</option>
          <option value="size">Sort: Size</option>
          <option value="category">Sort: Type</option>
        </select>

        <!-- Sort direction -->
        <button class="btn btn-outline-secondary btn-sm" id="btnSortDir" title="Toggle sort direction">
          <i class="bi bi-sort-down" id="sortDirIcon"></i>
        </button>

        <div class="ms-auto d-flex gap-2 align-items-center">
          <!-- Items count -->
          <small class="text-muted" id="itemsCount"></small>
          <!-- View toggle -->
          <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary active" id="btnGrid" title="Grid view"><i class="bi bi-grid-3x3-gap"></i></button>
            <button class="btn btn-outline-secondary" id="btnList" title="List view"><i class="bi bi-list-ul"></i></button>
          </div>
        </div>
      </div>

      <!-- Upload progress area -->
      <div id="uploadProgressArea" class="mb-3" style="display:none"></div>

      <!-- File area -->
      <div id="fileArea">
        <div class="text-muted text-center py-5">Loading…</div>
      </div>

      <!-- Pagination -->
      <nav class="mt-3" id="paginationNav" style="display:none">
        <ul class="pagination pagination-sm justify-content-center mb-0" id="pagination"></ul>
      </nav>

    </div><!-- col -->
  </div><!-- row -->
</div><!-- mediaApp -->


<!-- ══ MODALS ══════════════════════════════════════════════════════════════ -->

<!-- New Folder modal -->
<div class="modal fade" id="modalNewFolder" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title">New Folder</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <label class="form-label small">Folder name</label>
        <input type="text" class="form-control form-control-sm" id="newFolderName" placeholder="e.g. photos-2024">
        <div class="form-text">Allowed: letters, numbers, hyphens, underscores.</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary btn-sm" id="btnNewFolderConfirm">Create</button>
      </div>
    </div>
  </div>
</div>

<!-- Rename modal -->
<div class="modal fade" id="modalRename" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title">Rename</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <label class="form-label small">New name</label>
        <input type="text" class="form-control form-control-sm" id="renameInput">
        <div id="renameWarning" class="alert alert-warning mt-2 small" style="display:none">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          Renaming a folder will change the URL path of all files inside it. Update any existing links manually.
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary btn-sm" id="btnRenameConfirm">Rename</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete File modal -->
<div class="modal fade" id="modalDeleteFile" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title text-danger">Delete File</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <p>Are you sure you want to delete <strong id="deleteFileName"></strong>?</p>
        <p class="text-muted small mb-0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger btn-sm" id="btnDeleteFileConfirm">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Folder modal -->
<div class="modal fade" id="modalDeleteFolder" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title text-danger">Delete Folder</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <p>Delete folder <strong id="deleteFolderName"></strong>?</p>
        <div id="deleteFolderContents" class="alert alert-warning small" style="display:none">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          This folder contains <strong id="deleteFolderCount"></strong>. All contents will be permanently deleted.
        </div>
        <p class="text-muted small mb-0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger btn-sm" id="btnDeleteFolderConfirm">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Move File modal -->
<div class="modal fade" id="modalMove" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title">Move File</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <p class="small">Moving: <strong id="moveFileName"></strong></p>
        <label class="form-label small fw-semibold">Select destination folder:</label>
        <div id="moveFolderTree" class="border rounded p-2" style="max-height:280px;overflow-y:auto">
          <div class="text-muted small">Loading folders…</div>
        </div>
      </div>
      <div class="modal-footer">
        <span class="me-auto small text-muted">Selected: <span id="moveDestLabel">—</span></span>
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary btn-sm" id="btnMoveConfirm" disabled>Move Here</button>
      </div>
    </div>
  </div>
</div>

<!-- Copy URL toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">
  <div id="copyToast" class="toast align-items-center text-bg-success border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body"><i class="bi bi-clipboard-check me-1"></i> URL copied to clipboard</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>


<!-- ══ CONFIG for JS ═══════════════════════════════════════════════════════ -->
<script>
  const MEDIA_API_PREFIX = '/<%= passData.apiPrefix %>/adminMedia';
  const MEDIA_URL_BASE   = '/<%= passData.plugin.adminMedia.mediaDir %>';
  const ITEMS_PER_PAGE   = <%= passData.plugin.adminMedia.itemsPerPage %>;
</script>
<script src="/<%= passData.adminPrefix %>/mediaManagement/media.js"></script>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
