// This file follows the JSON5 standard - comments and trailing commas are supported
{
  "schemaVersion": 1,  // Versione della STRUTTURA del file (incrementare quando cambiano le chiavi). Vedi docs/decisions/config-lifecycle.it.md
  "active": 1,
  "weight": 0,

  // Nessuna dipendenza da altri plugin: csrfProtection è un servizio core-level.
  // Usa core/patternMatcher.js per gli exemptPaths (modulo del core, non un plugin).
  "dependency": {},
  "nodeModuleDependency": {},

  "custom": {
    // Interruttore generale. false → l'oggetto condiviso ritorna null e il
    // route-wrap del core salta la validazione (degradazione graziosa, nessun blocco).
    "enabled": true,

    // Metodi HTTP "mutanti" e quindi protetti. GET/HEAD/OPTIONS sempre esenti.
    // 'DEL' è normalizzato a 'DELETE' (ctx.method è sempre 'DELETE').
    "protectedMethods": ["POST", "PUT", "DELETE", "PATCH"],

    // Nome dell'header con cui i client (fetch/XHR) inviano il token.
    "tokenHeaderName": "X-CSRF-Token",
    // Nome del campo hidden con cui i form classici inviano il token.
    "tokenFieldName": "_csrf",
    // Nome del <meta> iniettato nell'<head> da cui l'interceptor legge il token.
    "metaName": "csrf-token",

    // Dietro reverse proxy: legge X-Forwarded-Host / X-Forwarded-Proto per
    // ricostruire l'origin atteso. Attivare SOLO se il proxy è fidato.
    "trustProxy": false,

    // Controllo Origin/Referer (secondo layer, oltre al token).
    "originCheck": {
      "enabled": true,
      // Origin aggiuntivi consentiti oltre a quello della richiesta (scheme://host).
      // Es. ["https://cms.example.com"]. Vuoto = solo same-origin dinamico.
      "allowedOrigins": [],
    },

    // Percorsi esenti dalla protezione (pattern: exact, *, **, regex: via core/patternMatcher).
    // Vuoto di default. Utile per webhook / API server-to-server con altra autenticazione.
    "exemptPaths": [],

    // Stato HTTP restituito quando la validazione fallisce.
    "failureStatus": 403,

    // Log a console di ogni richiesta bloccata.
    "enableLogging": true,

    // Se true, errori di validazione della configurazione al boot fanno crashare l'avvio.
    "strictValidation": false,
  },
}
