<!--
  Plugin: adminUsers
  Page: login
  Template standard: Plugin Pages System
  Customization: themes/{themeName}/pluginsEndpointsMarkup/adminUsers/login/
-->
<!DOCTYPE html>
<html lang="it">

<!-- Include theme head partial (contains Bootstrap, meta tags, etc.) -->
<%- include(passData.themeSys.getThemePartPath('head.ejs')) %>

<!-- Inject theme custom CSS for this specific plugin page -->
<%- passData.themeSys.injectPluginCss() %>

<!-- Inject theme custom JS for this specific plugin page -->
<%- passData.themeSys.injectPluginJs() %>

<title>Login - ital8cms</title>
</head>

<body class="plugin-page plugin-adminUsers page-login">

<!-- Include theme header partial (navigation, branding, etc.) -->
<%- include(passData.themeSys.getThemePartPath('header.ejs')) %>

<!-- Inject custom HTML BEFORE main content (from theme) -->
<%- passData.themeSys.injectPluginHtmlBefore() %>

<%
// Costruisci referrerTo da passData (per redirect dopo login)
const referrerTo = passData.ctx.headers.referer || '/';
%>

<!-- Main plugin content -->
<main class="container">
  <div class="row justify-content-center align-items-center vh-100">
    <div class="col-md-6 col-xl-4">
      <div class="card">
        <div class="card-body">
          <h1 class="card-title text-center mb-4">Login</h1>

          <!-- Messaggio di errore (mostrato via query param) -->
          <div id="errorDiv" class="alert alert-danger mb-3 d-none">
            <strong>Errore:</strong> <span id="errorMessage">Credenziali non valide</span>
          </div>

          <!-- Form login (POST to API endpoint) -->
          <form id="loginForm" method="POST" action="/<%= passData.apiPrefix %>/adminUsers/login">
            <!-- Campo hidden per redirect dopo login -->
            <input type="hidden" id="referrerTo" name="referrerTo" value="<%= referrerTo %>">

            <!-- Token CSRF (anti cross-site request forgery) -->
            <%- csrfField(passData) %>

            <!-- Username -->
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" class="form-control" id="username" name="username" required autofocus>
            </div>

            <!-- Password -->
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" name="password" required>
            </div>

            <!-- Submit button -->
            <button type="submit" id="loginButton" class="btn btn-primary w-100">Accedi</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Inject custom HTML AFTER main content (from theme) -->
<%- passData.themeSys.injectPluginHtmlAfter() %>

<!-- Include theme footer partial (scripts, closing tags) -->
<%- include(passData.themeSys.getThemePartPath('footer.ejs')) %>

<!-- Page-specific JavaScript -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const params = new URLSearchParams(window.location.search);

    // Se esiste il parametro "referrerTo", aggiorna il campo hidden (con validazione Open Redirect)
    if (params.has("referrerTo")) {
      const referrerTo = params.get("referrerTo");
      // Accetta solo path interni: deve iniziare con / e non con // o /\ (Open Redirect prevention)
      if (referrerTo.startsWith('/') && !referrerTo.startsWith('//') && !referrerTo.startsWith('/\\')) {
        document.getElementById("referrerTo").value = referrerTo;
      }
      // Se non valido, mantiene il valore server-side (dal Referer header, già validato)
    }

    // Se esiste il parametro "error", mostra il messaggio appropriato
    if (params.has('error')) {
      const errorType = params.get('error');
      const messageEl = document.getElementById('errorMessage');
      if (errorType === 'rateLimited') {
        // Troppi tentativi: comunica il tempo di attesa stimato
        const retryAfter = parseInt(params.get('retryAfter'), 10);
        let wait = 'qualche minuto';
        if (Number.isFinite(retryAfter) && retryAfter > 0) {
          const minutes = Math.ceil(retryAfter / 60);
          wait = minutes > 1 ? (minutes + ' minuti') : '1 minuto';
        }
        messageEl.textContent = 'Troppi tentativi falliti. Riprova tra ' + wait + '.';
      } else {
        messageEl.textContent = 'Credenziali non valide';
      }
      document.getElementById('errorDiv').classList.remove('d-none');
    }
  });
</script>

</body>
</html>