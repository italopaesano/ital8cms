<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>
<link rel="stylesheet" href="/<%= passData.adminPrefix %>/seoManagement/editor.css">

<div class="container mt-4">

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- BREADCRUMB + TITLE -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <a href="/<%= passData.adminPrefix %>/seoManagement/index.ejs">
          <%= __({it: 'Gestione SEO', en: 'SEO Management'}, passData.ctx) %>
        </a>
      </li>
      <li class="breadcrumb-item active">
        <%= __({it: 'Regole Per Pagina', en: 'Per-Page Rules'}, passData.ctx) %>
      </li>
    </ol>
  </nav>

  <h3 class="mb-2">
    <%= __({it: 'Regole SEO Per Pagina', en: 'Per-Page SEO Rules'}, passData.ctx) %>
  </h3>

  <p class="text-muted mb-1">
    <%= __({
      it: 'Definisci metadati SEO specifici per singole pagine o gruppi di pagine usando pattern URL. Le regole qui configurate hanno la precedenza sui valori globali.',
      en: 'Define SEO metadata for individual pages or groups of pages using URL patterns. Rules configured here override the global defaults.'
    }, passData.ctx) %>
  </p>
  <details class="mb-3">
    <summary class="text-muted small">
      <%= __({it: 'Approfondisci...', en: 'Learn more...'}, passData.ctx) %>
    </summary>
    <div class="small text-muted mt-1 ps-2 border-start">
      <%- __({
        it: `Il file <code>seoPages.json5</code> è scritto in formato JSON5: supporta commenti (<code>//</code> e <code>/* */</code>), virgole finali e chiavi non quotate.
             Ogni chiave dell'oggetto radice è un <strong>pattern URL</strong> a cui si applicano le regole.<br><br>
             <strong>Tipi di pattern e priorità:</strong><br>
             <code>/about.ejs</code> — match esatto (priorità 1000, la più alta)<br>
             <code>regex:^/product/\\d+$</code> — espressione regolare (priorità 500)<br>
             <code>/blog/*.ejs</code> — wildcard singolo, un solo segmento (priorità 300)<br>
             <code>/docs/**</code> — wildcard ricorsivo, tutti i livelli (priorità 100)<br><br>
             <strong>Campi supportati per ogni regola:</strong>
             <code>title</code>, <code>description</code>, <code>keywords</code>, <code>robots</code>, <code>ogType</code>, <code>ogImage</code>, <code>twitterCardType</code>, <code>sitemap</code> (oggetto con <code>priority</code> e <code>changefreq</code>, oppure <code>false</code> per escludere).<br><br>
             <strong>Multilingua:</strong> ogni campo testuale può essere una stringa semplice o un oggetto <code>{"it": "...", "en": "..."}</code>.
             Se il plugin <code>simpleI18n</code> è attivo, viene usata la lingua corrente dell'utente; altrimenti viene usata la prima lingua disponibile nell'oggetto.`,
        en: `The <code>seoPages.json5</code> file is written in JSON5 format: it supports comments (<code>//</code> and <code>/* */</code>), trailing commas, and unquoted keys.
             Each key of the root object is a <strong>URL pattern</strong> to which the rules apply.<br><br>
             <strong>Pattern types and priority:</strong><br>
             <code>/about.ejs</code> — exact match (priority 1000, highest)<br>
             <code>regex:^/product/\\d+$</code> — regular expression (priority 500)<br>
             <code>/blog/*.ejs</code> — single wildcard, one segment only (priority 300)<br>
             <code>/docs/**</code> — recursive wildcard, all levels (priority 100)<br><br>
             <strong>Supported fields per rule:</strong>
             <code>title</code>, <code>description</code>, <code>keywords</code>, <code>robots</code>, <code>ogType</code>, <code>ogImage</code>, <code>twitterCardType</code>, <code>sitemap</code> (object with <code>priority</code> and <code>changefreq</code>, or <code>false</code> to exclude).<br><br>
             <strong>Multilingual:</strong> each text field can be a plain string or an object <code>{"it": "...", "en": "..."}</code>.
             If the <code>simpleI18n</code> plugin is active, the user's current language is used; otherwise the first available language in the object is used.`
      }, passData.ctx) %>
    </div>
  </details>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- ALERT AREA -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div id="alertArea"></div>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- TOP ACTION BAR -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div class="d-flex gap-2 mb-2">
    <button type="button" id="btnValidate" class="btn btn-outline-info btn-sm">
      <i class="bi bi-check-circle"></i>
      <%= __({it: 'Valida JSON5', en: 'Validate JSON5'}, passData.ctx) %>
    </button>
    <button type="button" id="btnSave" class="btn btn-primary btn-sm">
      <i class="bi bi-save"></i>
      <%= __({it: 'Salva', en: 'Save'}, passData.ctx) %>
    </button>
    <a href="/<%= passData.adminPrefix %>/seoManagement/index.ejs"
       class="btn btn-link btn-sm nav-link-action"
       id="linkCancel">
      <%= __({it: 'Annulla', en: 'Cancel'}, passData.ctx) %>
    </a>
  </div>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- SNIPPET TOOLBAR -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div class="snippet-toolbar-card mb-3">
    <div class="snippet-toolbar-header">
      <small class="fw-semibold text-muted">
        <i class="bi bi-puzzle"></i>
        <%= __({it: 'Inserisci snippet', en: 'Insert snippet'}, passData.ctx) %>
      </small>
    </div>
    <div class="snippet-toolbar-body">
      <div class="d-flex flex-wrap gap-1">
        <button class="btn btn-outline-secondary btn-sm" id="snippetExact">
          <i class="bi bi-plus"></i>
          <%= __({it: 'Regola Esatta', en: 'Exact Rule'}, passData.ctx) %>
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="snippetWildcard">
          <i class="bi bi-plus"></i> Wildcard (*)
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="snippetRecursive">
          <i class="bi bi-plus"></i> Wildcard (**)
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="snippetRegex">
          <i class="bi bi-plus"></i> Regex
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="snippetMultilingual">
          <i class="bi bi-plus"></i>
          <%= __({it: 'Multilingua', en: 'Multilingual'}, passData.ctx) %>
        </button>
      </div>
    </div>

    <!-- PATTERN REFERENCE (collassabile) — dentro la snippet toolbar card -->
    <div class="snippet-toolbar-separator"></div>
    <div class="snippet-toolbar-body pt-1">
      <details class="pattern-reference">
        <summary>
          <i class="bi bi-book"></i>
          <%= __({it: 'Riferimento Pattern', en: 'Pattern Reference'}, passData.ctx) %>
        </summary>
        <div class="pattern-reference-body">
          <table class="table table-sm mb-0">
            <tbody>
              <tr>
                <td><code>/about.ejs</code></td>
                <td><%= __({it: 'Match esatto (priorità 1000)', en: 'Exact match (priority 1000)'}, passData.ctx) %></td>
              </tr>
              <tr>
                <td><code>/blog/*.ejs</code></td>
                <td><%= __({it: 'Wildcard singolo — un livello (priorità 300)', en: 'Single wildcard — one level (priority 300)'}, passData.ctx) %></td>
              </tr>
              <tr>
                <td><code>/docs/**</code></td>
                <td><%= __({it: 'Wildcard ricorsivo — tutti i livelli (priorità 100)', en: 'Recursive wildcard — all levels (priority 100)'}, passData.ctx) %></td>
              </tr>
              <tr>
                <td><code>regex:^/product/\d+$</code></td>
                <td><%= __({it: 'Espressione regolare (priorità 500)', en: 'Regular expression (priority 500)'}, passData.ctx) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </details>
    </div>

  </div>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- MESSAGES AREA -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div id="editorMessages" class="messages-area mb-3"></div>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- DIFF PANEL (collassabile — si popola dopo il salvataggio) -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div class="diff-panel mb-4">
    <div class="diff-panel-header collapsed"
         data-bs-toggle="collapse"
         data-bs-target="#diffPanelBody"
         aria-expanded="false"
         aria-controls="diffPanelBody">
      <i class="bi bi-file-diff"></i>
      <span><%= __({it: 'Riepilogo Modifiche', en: 'Changes Summary'}, passData.ctx) %></span>
      <span id="diffCounter" class="diff-counter ms-2"></span>
      <span id="diffSavedBadge" class="diff-saved-badge ms-2 d-none">
        <%= __({it: 'Salvataggio effettuato', en: 'Save completed'}, passData.ctx) %>
      </span>
      <i class="bi bi-chevron-right ms-auto diff-chevron"></i>
    </div>

    <div id="diffPanelBody" class="collapse">

      <div id="diffNoSaveYet" class="diff-no-changes">
        <i class="bi bi-clock-history"></i>
        <%= __({it: 'Nessun salvataggio ancora eseguito', en: 'No save performed yet'}, passData.ctx) %>
      </div>

      <div id="diffContent" class="d-none p-3">
        <!-- Before panel -->
        <div class="diff-subpanel diff-before mb-2">
          <div class="diff-subpanel-header">
            <i class="bi bi-clock-history"></i>
            <%= __({it: 'Prima', en: 'Before'}, passData.ctx) %>
          </div>
          <pre id="diffBefore" class="diff-pre"></pre>
        </div>

        <!-- Arrow separator -->
        <div class="diff-arrow text-center mb-2">
          <i class="bi bi-arrow-down"></i>
        </div>

        <!-- After panel -->
        <div class="diff-subpanel diff-after">
          <div class="diff-subpanel-header">
            <i class="bi bi-pencil-square"></i>
            <%= __({it: 'Dopo (salvato)', en: 'After (saved)'}, passData.ctx) %>
          </div>
          <pre id="diffAfter" class="diff-pre"></pre>
        </div>
      </div>

    </div>
  </div>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- JSON5 EDITOR -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <h5 class="mb-2">
    <i class="bi bi-code-slash"></i>
    <%= __({it: 'Editor JSON5', en: 'JSON5 Editor'}, passData.ctx) %>
  </h5>
  <textarea id="jsonEditor" class="seo-editor-textarea" rows="40" spellcheck="false"></textarea>


</div>

<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<!-- MODAL — Modifiche non salvate -->
<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<div class="modal fade" id="unsavedChangesModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <%= __({it: 'Modifiche non salvate', en: 'Unsaved Changes'}, passData.ctx) %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">
          <%= __({it: 'Ci sono modifiche non salvate nell\'editor. Cosa vuoi fare?', en: 'There are unsaved changes in the editor. What do you want to do?'}, passData.ctx) %>
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" id="modalBtnDiscard">
          <i class="bi bi-x-circle"></i>
          <%= __({it: 'Prosegui senza salvare', en: 'Continue without saving'}, passData.ctx) %>
        </button>
        <button type="button" class="btn btn-primary" id="modalBtnSave">
          <i class="bi bi-save"></i>
          <%= __({it: 'Salva e prosegui', en: 'Save and continue'}, passData.ctx) %>
        </button>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="modalBtnCancel">
          <%= __({it: 'Annulla', en: 'Cancel'}, passData.ctx) %>
        </button>
      </div>
    </div>
  </div>
</div>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
<script src="/<%= passData.adminPrefix %>/seoManagement/editor.js"></script>
<script>
  const apiPrefix  = '<%= passData.apiPrefix %>';
  const adminPrefix = '<%= passData.adminPrefix %>';

  const i18n = {
    saved:           '<%= __({it: "Regole salvate con successo.", en: "Rules saved successfully."}, passData.ctx) %>',
    saveError:       '<%= __({it: "Errore nel salvataggio.", en: "Error saving."}, passData.ctx) %>',
    loadError:       '<%= __({it: "Errore nel caricamento.", en: "Error loading."}, passData.ctx) %>',
    validationOk:    '<%= __({it: "Validazione superata.", en: "Validation passed."}, passData.ctx) %>',
    warningsConfirm: '<%= __({it: "Ci sono avvisi. Procedere comunque con il salvataggio?", en: "There are warnings. Proceed with save anyway?"}, passData.ctx) %>',
  };

  (function () {
    'use strict';

    // ── DOM references ───────────────────────────────────────────────────────
    const editor          = document.getElementById('jsonEditor');
    const btnValidate     = document.getElementById('btnValidate');
    const btnSave         = document.getElementById('btnSave');
    const linkCancel      = document.getElementById('linkCancel');
    const messagesEl      = document.getElementById('editorMessages');

    const diffPanelHeader = document.querySelector('.diff-panel-header');
    const diffCounter     = document.getElementById('diffCounter');
    const diffSavedBadge  = document.getElementById('diffSavedBadge');
    const diffNoSaveYet   = document.getElementById('diffNoSaveYet');
    const diffContent     = document.getElementById('diffContent');
    const diffBefore      = document.getElementById('diffBefore');
    const diffAfter       = document.getElementById('diffAfter');

    const modalEl             = document.getElementById('unsavedChangesModal');
    const unsavedChangesModal = new bootstrap.Modal(modalEl);
    const modalBtnDiscard     = document.getElementById('modalBtnDiscard');
    const modalBtnSave        = document.getElementById('modalBtnSave');

    const snippetExact        = document.getElementById('snippetExact');
    const snippetWildcard     = document.getElementById('snippetWildcard');
    const snippetRecursive    = document.getElementById('snippetRecursive');
    const snippetRegex        = document.getElementById('snippetRegex');
    const snippetMultilingual = document.getElementById('snippetMultilingual');

    // Store original button HTML for spinner restore (Fase 6)
    const btnValidateOriginalHtml = btnValidate.innerHTML;
    const btnSaveOriginalHtml     = btnSave.innerHTML;

    // ── State ────────────────────────────────────────────────────────────────
    let savedContent  = '';
    let pendingNavUrl = null;

    const isDirty = () => editor.value !== savedContent;

    // ── Dirty indicator (Fase 4) ─────────────────────────────────────────────
    function updateDirtyIndicator() {
      if (isDirty()) {
        btnSave.classList.remove('btn-primary');
        btnSave.classList.add('btn-warning');
      } else {
        btnSave.classList.remove('btn-warning');
        btnSave.classList.add('btn-primary');
      }
    }

    editor.addEventListener('input', updateDirtyIndicator);

    // ── Spinner helpers (Fase 6) ─────────────────────────────────────────────
    const SPINNER_HTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';

    function setButtonLoading(btn, loading) {
      if (loading) {
        btn.disabled = true;
        btn.innerHTML = SPINNER_HTML;
      } else {
        btn.disabled = false;
        btn.innerHTML = btn === btnValidate ? btnValidateOriginalHtml : btnSaveOriginalHtml;
        updateDirtyIndicator();
      }
    }

    // ── Messages area ────────────────────────────────────────────────────────
    function showMessages(errors, warnings) {
      messagesEl.innerHTML = '';
      (errors   || []).forEach(msg => {
        const div = document.createElement('div');
        div.className = 'message-item message-error';
        div.textContent = msg;
        messagesEl.appendChild(div);
      });
      (warnings || []).forEach(msg => {
        const div = document.createElement('div');
        div.className = 'message-item message-warning';
        div.textContent = msg;
        messagesEl.appendChild(div);
      });
    }

    function showSuccessMessage(text) {
      messagesEl.innerHTML = '';
      const div = document.createElement('div');
      div.className = 'message-item message-success';
      div.textContent = text;
      messagesEl.appendChild(div);
    }

    function clearMessages() { messagesEl.innerHTML = ''; }

    // ── Diff panel ───────────────────────────────────────────────────────────
    function populateDiff(beforeText, afterText) {
      diffBefore.textContent = beforeText;
      diffAfter.textContent  = afterText;
      diffNoSaveYet.classList.add('d-none');
      diffContent.classList.remove('d-none');
      diffSavedBadge.classList.remove('d-none');

      const beforeLines = beforeText.split('\n');
      const afterLines  = afterText.split('\n');
      let changes = 0;
      const maxLen = Math.max(beforeLines.length, afterLines.length);
      for (let i = 0; i < maxLen; i++) {
        if (beforeLines[i] !== afterLines[i]) changes++;
      }
      diffCounter.textContent = changes > 0 ? String(changes) : '';

      if (diffPanelHeader.classList.contains('collapsed')) {
        diffPanelHeader.click();
      }
    }

    // ── API helpers ──────────────────────────────────────────────────────────
    async function apiValidate(content) {
      const resp = await fetch(`/${apiPrefix}/adminSeo/validate-page-rules`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content }),
      });
      return resp.json();
    }

    async function apiSave(content) {
      const resp = await fetch(`/${apiPrefix}/adminSeo/save-page-rules`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content }),
      });
      return resp.json();
    }

    // ── Load rules on page init ──────────────────────────────────────────────
    async function loadRules() {
      try {
        const resp   = await fetch(`/${apiPrefix}/adminSeo/load-page-rules`);
        const result = await resp.json();
        if (!result.success) {
          showAlert(escapeHtml(i18n.loadError + (result.error ? ': ' + result.error : '')), 'danger');
          return;
        }
        savedContent = result.raw || '';
        editor.value = savedContent;
        updateDirtyIndicator();
      } catch (err) {
        showAlert(escapeHtml(i18n.loadError), 'danger');
      }
    }

    // ── Validate button (Fase 6: spinner) ────────────────────────────────────
    btnValidate.addEventListener('click', async () => {
      clearMessages();
      setButtonLoading(btnValidate, true);
      let validation;
      try {
        validation = await apiValidate(editor.value);
      } catch (err) {
        showAlert(escapeHtml(i18n.saveError), 'danger');
        setButtonLoading(btnValidate, false);
        return;
      }
      setButtonLoading(btnValidate, false);
      if (validation.valid) {
        if (validation.warnings && validation.warnings.length > 0) {
          showMessages([], validation.warnings);
        } else {
          showSuccessMessage(i18n.validationOk);
        }
      } else {
        showMessages(validation.errors, validation.warnings);
      }
    });

    // ── Save logic (Fase 2: no alert success; Fase 6: spinner) ───────────────
    async function performSave() {
      const content = editor.value;
      clearMessages();
      setButtonLoading(btnSave, true);

      // Step 1: validate
      let validation;
      try {
        validation = await apiValidate(content);
      } catch (err) {
        showAlert(escapeHtml(i18n.saveError), 'danger');
        setButtonLoading(btnSave, false);
        return false;
      }

      if (!validation.valid) {
        showMessages(validation.errors, validation.warnings);
        setButtonLoading(btnSave, false);
        return false;
      }

      // Step 2: if warnings, ask for confirmation (spinner paused during confirm)
      if (validation.warnings && validation.warnings.length > 0) {
        showMessages([], validation.warnings);
        setButtonLoading(btnSave, false);
        if (!window.confirm(i18n.warningsConfirm)) return false;
        setButtonLoading(btnSave, true);
      }

      // Step 3: save
      const beforeContent = savedContent;
      try {
        const result = await apiSave(content);
        setButtonLoading(btnSave, false);
        if (!result.success) {
          const errors = result.errors || (result.error ? [result.error] : []);
          showMessages(errors, result.warnings || []);
          showAlert(escapeHtml(i18n.saveError), 'danger');
          return false;
        }
        savedContent = content;
        updateDirtyIndicator();                 // Fase 4: torna btn-primary
        showSuccessMessage(i18n.saved);         // Fase 2: solo editorMessages
        populateDiff(beforeContent, content);
        return true;
      } catch (err) {
        setButtonLoading(btnSave, false);
        showAlert(escapeHtml(i18n.saveError), 'danger');
        return false;
      }
    }

    btnSave.addEventListener('click', () => performSave());

    // ── Ctrl+S / Cmd+S (Fase 5) ──────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 's' && (e.ctrlKey || e.metaKey)) {
        e.preventDefault();
        if (!btnSave.disabled) performSave();
      }
    });

    // ── Unsaved changes modal ────────────────────────────────────────────────
    function interceptNavigation(href) {
      if (!isDirty()) {
        window.location.href = href;
        return;
      }
      pendingNavUrl = href;
      unsavedChangesModal.show();
    }

    linkCancel.addEventListener('click', (e) => {
      if (!isDirty()) return;
      e.preventDefault();
      interceptNavigation(linkCancel.href);
    });

    const breadcrumbLink = document.querySelector('.breadcrumb-item:not(.active) a');
    if (breadcrumbLink) {
      breadcrumbLink.addEventListener('click', (e) => {
        if (!isDirty()) return;
        e.preventDefault();
        interceptNavigation(breadcrumbLink.href);
      });
    }

    modalBtnDiscard.addEventListener('click', () => {
      unsavedChangesModal.hide();
      if (pendingNavUrl) window.location.href = pendingNavUrl;
      pendingNavUrl = null;
    });

    modalBtnSave.addEventListener('click', async () => {
      unsavedChangesModal.hide();
      const saved = await performSave();
      if (saved && pendingNavUrl) {
        window.location.href = pendingNavUrl;
        pendingNavUrl = null;
      }
    });

    // ── Smart snippet insertion (Fase 3) ─────────────────────────────────────
    const SNIPPETS = {
      exact: [
        '',
        '  "/page.ejs": {',
        '    "title": "Page Title",',
        '    "description": "Page description",',
        '    "robots": "index, follow"',
        '  },',
        '',
      ].join('\n'),

      wildcard: [
        '',
        '  "/section/*.ejs": {',
        '    "title": "Section Page",',
        '    "description": "Section description"',
        '  },',
        '',
      ].join('\n'),

      recursive: [
        '',
        '  "/docs/**": {',
        '    "robots": "noindex, nofollow"',
        '  },',
        '',
      ].join('\n'),

      regex: [
        '',
        '  "regex:^/product/\\\\d+\\.ejs$": {',
        '    "title": "Product",',
        '    "ogType": "product"',
        '  },',
        '',
      ].join('\n'),

      multilingual: [
        '',
        '  "/page.ejs": {',
        '    "title": { "it": "Titolo", "en": "Title" },',
        '    "description": { "it": "Descrizione", "en": "Description" }',
        '  },',
        '',
      ].join('\n'),
    };

    // Inserisce sempre prima dell'ultima `}` del contenuto
    function insertSnippetSmart(text) {
      const content    = editor.value;
      const lastBrace  = content.lastIndexOf('}');
      if (lastBrace === -1) {
        editor.value = content + text;
        editor.selectionStart = editor.selectionEnd = editor.value.length;
      } else {
        const before = content.substring(0, lastBrace);
        const after  = content.substring(lastBrace);
        editor.value = before + text + after;
        editor.selectionStart = editor.selectionEnd = lastBrace + text.length;
      }
      editor.focus();
      updateDirtyIndicator();
    }

    snippetExact.addEventListener('click',        () => insertSnippetSmart(SNIPPETS.exact));
    snippetWildcard.addEventListener('click',     () => insertSnippetSmart(SNIPPETS.wildcard));
    snippetRecursive.addEventListener('click',    () => insertSnippetSmart(SNIPPETS.recursive));
    snippetRegex.addEventListener('click',        () => insertSnippetSmart(SNIPPETS.regex));
    snippetMultilingual.addEventListener('click', () => insertSnippetSmart(SNIPPETS.multilingual));

    // ── Init ─────────────────────────────────────────────────────────────────
    loadRules();

  })();
</script>
