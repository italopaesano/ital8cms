<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<link rel="stylesheet" href="/<%= passData.adminPrefix %>/rateLimiterManagement/rateLimiter-admin.css">
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>

<div class="container mt-4 rl-admin">

  <ul class="nav nav-pills mb-3 rl-nav">
    <li class="nav-item"><a class="nav-link" href="/<%= passData.adminPrefix %>/rateLimiterManagement/index.ejs"><%= __({it: 'Panoramica', en: 'Overview'}, passData.ctx) %></a></li>
    <li class="nav-item"><a class="nav-link active" href="/<%= passData.adminPrefix %>/rateLimiterManagement/rules.ejs"><%= __({it: 'Regole', en: 'Rules'}, passData.ctx) %></a></li>
    <li class="nav-item"><a class="nav-link" href="/<%= passData.adminPrefix %>/rateLimiterManagement/settings.ejs"><%= __({it: 'Impostazioni', en: 'Settings'}, passData.ctx) %></a></li>
  </ul>

  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <h3 class="mb-0"><%= __({it: 'Regole protette', en: 'Protected rules'}, passData.ctx) %> <code class="fs-6">protectedRoutes.json5</code></h3>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <div class="btn-group btn-group-sm" role="group" aria-label="view toggle">
        <input type="radio" class="btn-check" name="rlRulesView" id="viewForm" autocomplete="off" checked>
        <label class="btn btn-outline-secondary" for="viewForm"><%= __({it: 'Form', en: 'Form'}, passData.ctx) %></label>
        <input type="radio" class="btn-check" name="rlRulesView" id="viewJson" autocomplete="off">
        <label class="btn btn-outline-secondary" for="viewJson">JSON5</label>
      </div>
      <button id="btnValidate" class="btn btn-outline-info btn-sm">✓ <%= __({it: 'Valida', en: 'Validate'}, passData.ctx) %></button>
      <button id="btnSave" class="btn btn-primary btn-sm">💾 <%= __({it: 'Salva', en: 'Save'}, passData.ctx) %></button>
    </div>
  </div>

  <div id="globalAlert" class="alert d-none" role="alert"></div>
  <div id="disabledBanner" class="alert alert-warning d-none">
    <%= __({
      it: 'Il plugin rateLimiter è disattivato: puoi vedere le regole ma non validarle/salvarle.',
      en: 'The rateLimiter plugin is disabled: you can view the rules but not validate/save them.'
    }, passData.ctx) %>
  </div>
  <div class="alert alert-info py-2 small">
    <%= __({
      it: 'Nei campi numerici lascia vuoto per ereditare dai defaults globali. La vista Form normalizza il JSON5 (i commenti del file non vengono preservati); per mantenere i commenti modifica e salva dalla vista JSON5.',
      en: 'Leave numeric fields empty to inherit the global defaults. The Form view normalizes JSON5 (file comments are not preserved); to keep comments edit and save from the JSON5 view.'
    }, passData.ctx) %>
  </div>

  <div id="messages" class="messages-area mb-2"></div>

  <%# ───────────── VISTA C: FORM (card per regola) ───────────── %>
  <div id="rulesFormView">
    <div id="rulesContainer"></div>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnAddRule">+ <%= __({it: 'Aggiungi regola', en: 'Add rule'}, passData.ctx) %></button>
  </div>

  <%# ───────────── VISTA B: EDITOR JSON5 GREZZO ───────────── %>
  <div id="rulesJsonView" class="d-none">
    <textarea id="rulesEditor" class="rl-editor form-control mb-2" rows="22" spellcheck="false"></textarea>
  </div>

  <div class="card mt-3">
    <div class="card-header small fw-semibold"><%= __({it: 'Riferimento campi', en: 'Field reference'}, passData.ctx) %></div>
    <div class="card-body small text-muted">
      <code>name (obbligatorio), pathPattern (opz.), findWindowSeconds, maxFailures, shortBlockSeconds, maxShortBlocks, longBlockSeconds, escalationResetSeconds</code>
      <p class="mb-0 mt-1"><%= __({
        it: '<code>pathPattern</code> abilita l\'enforcement L2 sulle pagine (PatternMatcher: *, **, regex:). I campi numerici vuoti ereditano dai defaults globali.',
        en: '<code>pathPattern</code> enables L2 page enforcement (PatternMatcher: *, **, regex:). Empty numeric fields inherit the global defaults.'
      }, passData.ctx) %></p>
    </div>
  </div>
</div>

<script>
  const apiPrefix   = '<%= passData.apiPrefix %>';
  const adminPrefix = '<%= passData.adminPrefix %>';
  const i18n = {
    saved:      '<%= __({it: "Regole salvate e ricaricate", en: "Rules saved and reloaded"}, passData.ctx) %>',
    valid:      '<%= __({it: "JSON5 valido", en: "Valid JSON5"}, passData.ctx) %>',
    parseError: '<%= __({it: "Impossibile importare nel form: il JSON5 contiene commenti o sintassi non importabile (modifica dalla vista JSON5)", en: "Cannot import into the form: the JSON5 contains comments or non-importable syntax (edit from the JSON5 view)"}, passData.ctx) %>',
    remove:     '<%= __({it: "rimuovi", en: "remove"}, passData.ctx) %>',
    namePlaceholder: '<%= __({it: "nome regola", en: "rule name"}, passData.ctx) %>',
  };
</script>
<script src="/<%= passData.adminPrefix %>/rateLimiterManagement/rules-editor.js"></script>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
