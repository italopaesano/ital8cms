<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<link rel="stylesheet" href="/<%= passData.adminPrefix %>/rateLimiterManagement/rateLimiter-admin.css">
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>

<div class="container mt-4 rl-admin">

  <ul class="nav nav-pills mb-3 rl-nav">
    <li class="nav-item"><a class="nav-link" href="/<%= passData.adminPrefix %>/rateLimiterManagement/index.ejs"><%= __({it: 'Panoramica', en: 'Overview'}, passData.ctx) %></a></li>
    <li class="nav-item"><a class="nav-link" href="/<%= passData.adminPrefix %>/rateLimiterManagement/rules.ejs"><%= __({it: 'Regole', en: 'Rules'}, passData.ctx) %></a></li>
    <li class="nav-item"><a class="nav-link active" href="/<%= passData.adminPrefix %>/rateLimiterManagement/settings.ejs"><%= __({it: 'Impostazioni', en: 'Settings'}, passData.ctx) %></a></li>
  </ul>

  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <h3 class="mb-0"><%= __({it: 'Impostazioni', en: 'Settings'}, passData.ctx) %> <code class="fs-6">pluginConfig.json5 → custom</code></h3>
    <div class="d-flex gap-2">
      <button id="btnValidate" class="btn btn-outline-info btn-sm">✓ <%= __({it: 'Valida', en: 'Validate'}, passData.ctx) %></button>
      <button id="btnSave" class="btn btn-primary btn-sm">💾 <%= __({it: 'Salva', en: 'Save'}, passData.ctx) %></button>
      <button id="btnSaveRestart" class="btn btn-warning btn-sm">⟳ <%= __({it: 'Salva e riavvia', en: 'Save & restart'}, passData.ctx) %></button>
    </div>
  </div>

  <div id="globalAlert" class="alert d-none" role="alert"></div>
  <div id="disabledBanner" class="alert alert-warning d-none">
    <%= __({
      it: 'Il plugin rateLimiter è disattivato: puoi vedere le impostazioni ma non validarle/salvarle.',
      en: 'The rateLimiter plugin is disabled: you can view the settings but not validate/save them.'
    }, passData.ctx) %>
  </div>

  <div class="alert alert-info py-2 small">
    <%= __({
      it: 'Modifiche a defaults ed enforcement si applicano a caldo (reloadConfig). Parametri infrastrutturali (trustProxy, state.flushIntervalSeconds, log.*, sweepIntervalSeconds) richiedono il riavvio: usa "Salva e riavvia" (i blocchi attivi persistono).',
      en: 'Changes to defaults and enforcement apply hot (reloadConfig). Infrastructural params (trustProxy, state.flushIntervalSeconds, log.*, sweepIntervalSeconds) require a restart: use "Save & restart" (active blocks persist).'
    }, passData.ctx) %>
  </div>

  <div id="messages" class="messages-area mb-2"></div>

  <textarea id="configEditor" class="rl-editor form-control mb-3" rows="22" spellcheck="false"></textarea>

  <div class="card">
    <div class="card-header small fw-semibold"><%= __({it: 'Riferimento campi', en: 'Field reference'}, passData.ctx) %></div>
    <div class="card-body small text-muted">
      <code>enabled, trustProxy ⟳, defaults{findWindowSeconds, maxFailures, shortBlockSeconds, maxShortBlocks, longBlockSeconds, escalationResetSeconds}, state{flushIntervalSeconds ⟳}, log{enabled ⟳, rotateWhenBytes ⟳, retentionDays ⟳}, response{status, retryAfterHeader}, enforcement{enabled, globalLongBlock, status, redirectTo, exemptPaths}, sweepIntervalSeconds ⟳, enableLogging, strictValidation</code>
      <p class="mb-0 mt-1">⟳ = <%= __({it: 'richiede il riavvio', en: 'requires restart'}, passData.ctx) %></p>
    </div>
  </div>
</div>

<script>
  const apiPrefix   = '<%= passData.apiPrefix %>';
  const adminPrefix = '<%= passData.adminPrefix %>';
  const i18n = {
    saved:     '<%= __({it: "Impostazioni salvate e ricaricate", en: "Settings saved and reloaded"}, passData.ctx) %>',
    valid:     '<%= __({it: "JSON5 valido", en: "Valid JSON5"}, passData.ctx) %>',
    restarting:'<%= __({it: "Salvato — riavvio in corso…", en: "Saved — restarting…"}, passData.ctx) %>',
  };
</script>
<script src="/<%= passData.adminPrefix %>/rateLimiterManagement/settings-editor.js"></script>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
