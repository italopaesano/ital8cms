<%- include( passData.themeSys.getThemePartPath( 'head.ejs', passData ) ) %>
<%- include( passData.themeSys.getThemePartPath( 'header.ejs', passData ) ) %>

<link rel="stylesheet" href="/<%= passData.adminPrefix %>/navbarsManagement/editor.css">

<script>
  const apiPrefix = '<%= passData.apiPrefix %>';
  const adminPrefix = '<%= passData.adminPrefix %>';
  const currentFile = '<%= passData.query.file || '' %>';
</script>

<div class="container mt-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/<%= passData.adminPrefix %>/navbarsManagement/index.ejs"><%= __({it: 'Gestione Navbar', en: 'Navbar Management'}, passData.ctx) %></a></li>
      <li class="breadcrumb-item active" id="breadcrumbFile"><%= __({it: 'Modifica', en: 'Edit'}, passData.ctx) %></li>
    </ol>
  </nav>

  <h3><%= __({it: 'Modifica Navbar', en: 'Edit Navbar'}, passData.ctx) %>: <span id="fileNameDisplay" class="text-muted"></span></h3>

  <!-- Alert area -->
  <div id="alertArea"></div>

  <!-- Toolbar -->
  <div class="editor-toolbar mb-2">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="btn-group btn-group-sm">
        <button class="btn btn-outline-primary" id="btnAddItem" title="<%= __({it: 'Aggiungi Item', en: 'Add Item'}, passData.ctx) %>">
          <i class="bi bi-plus"></i> Item
        </button>
        <button class="btn btn-outline-secondary" id="btnFromFile" title="<%= __({it: 'Aggiungi Item da File', en: 'Add Item from File'}, passData.ctx) %>">
          From File
        </button>
        <button class="btn btn-outline-primary" id="btnAddDropdown" title="<%= __({it: 'Aggiungi Dropdown', en: 'Add Dropdown'}, passData.ctx) %>">
          <i class="bi bi-caret-down"></i> Dropdown
        </button>
        <button class="btn btn-outline-primary" id="btnAddSeparator" title="<%= __({it: 'Aggiungi Separator', en: 'Add Separator'}, passData.ctx) %>">
          | Sep
        </button>
        <button class="btn btn-outline-primary" id="btnAddDivider" title="<%= __({it: 'Aggiungi Divider', en: 'Add Divider'}, passData.ctx) %>">
          ── Div
        </button>
      </div>

      <!-- Section selector for append -->
      <div class="input-group input-group-sm" style="width: auto;">
        <span class="input-group-text"><%= __({it: 'Aggiungi a', en: 'Add to'}, passData.ctx) %>:</span>
        <select class="form-select form-select-sm" id="sectionSelect" style="width: auto;">
          <option value="left">Left</option>
          <option value="right">Right</option>
        </select>
      </div>

      <div class="vr d-none d-md-block"></div>

      <button class="btn btn-outline-danger btn-sm" id="btnTemplateEmpty" title="<%= __({it: 'Sostituisci con template vuoto', en: 'Replace with empty template'}, passData.ctx) %>">
        <i class="bi bi-file-earmark"></i> <%= __({it: 'Template Vuoto', en: 'Empty Template'}, passData.ctx) %>
      </button>
    </div>
  </div>

  <!-- Icon helper -->
  <div class="editor-icon-helper mb-2">
    <div class="d-flex align-items-center gap-2">
      <label class="form-label mb-0 text-nowrap"><%= __({it: 'Icona', en: 'Icon'}, passData.ctx) %>:</label>
      <input type="text" class="form-control form-control-sm" id="iconInput" placeholder="<i class='bi bi-house'></i>" style="max-width: 350px;">
      <span id="iconPreview" class="fs-5"></span>
    </div>
  </div>

  <!-- Preview section -->
  <div id="previewSection" style="display: none;" class="mb-4">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong><%= __({it: 'Anteprima', en: 'Preview'}, passData.ctx) %></strong>
        <button type="button" class="btn-close" id="btnClosePreview"></button>
      </div>
      <div class="card-body p-0">
        <div id="previewContainer"></div>
      </div>
      <div class="card-footer">
        <div id="previewInfo" class="small text-muted"></div>
        <div class="mt-2 small">
          <span class="badge bg-warning text-dark">&#x1F512;</span> = <%= __({it: 'Richiede autenticazione/ruolo', en: 'Requires authentication/role'}, passData.ctx) %>
          &nbsp;
          <span class="badge bg-info text-dark">&#x1F441;</span> = <%= __({it: 'Solo non autenticati', en: 'Non-authenticated only'}, passData.ctx) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="d-flex justify-content-between mt-3 mb-4">
    <div>
      <button id="btnValidate" class="btn btn-outline-info me-2">
        <i class="bi bi-check-circle"></i> <%= __({it: 'Valida', en: 'Validate'}, passData.ctx) %>
      </button>
      <button id="btnPreview" class="btn btn-outline-success me-2">
        <i class="bi bi-eye"></i> <%= __({it: 'Preview', en: 'Preview'}, passData.ctx) %> &#9654;
      </button>
      <button id="btnSave" class="btn btn-primary">
        <i class="bi bi-save"></i> <%= __({it: 'Salva', en: 'Save'}, passData.ctx) %>
      </button>
    </div>
    <a href="/<%= passData.adminPrefix %>/navbarsManagement/index.ejs" class="btn btn-outline-secondary">
      <%= __({it: 'Annulla', en: 'Cancel'}, passData.ctx) %>
    </a>
  </div>

  <!-- Messages area -->
  <div id="messagesArea" class="editor-messages mt-2"></div>

  <!-- Editor textarea (bottom) -->
  <textarea id="editorTextarea" class="form-control editor-textarea" rows="50" spellcheck="false"></textarea>
</div>

<!-- File Picker Modal -->
<div class="modal fade" id="filePickerModal" tabindex="-1" aria-labelledby="filePickerModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="filePickerModalLabel"><%= __({it: 'Seleziona File', en: 'Select File'}, passData.ctx) %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <!-- Tab navigation (visible only in developer mode) -->
        <ul class="nav nav-tabs mb-3" id="filePickerTabs" role="tablist" style="display: none;">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-www" data-bs-toggle="tab" data-bs-target="#tabpane-www" type="button" role="tab">/www</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-pluginPages" data-bs-toggle="tab" data-bs-target="#tabpane-pluginPages" type="button" role="tab">/pluginPages</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-admin" data-bs-toggle="tab" data-bs-target="#tabpane-admin" type="button" role="tab">/admin</button>
          </li>
        </ul>

        <!-- Filter -->
        <div class="mb-3">
          <label class="form-label small"><%= __({it: 'Filtro', en: 'Filter'}, passData.ctx) %>:</label>
          <select class="form-select form-select-sm" id="filePickerFilter" style="width: auto; display: inline-block;">
            <option value=".ejs">EJS only (.ejs)</option>
            <option value=".html">HTML only (.html)</option>
            <option value="*"><%= __({it: 'Tutti i file', en: 'All files'}, passData.ctx) %></option>
          </select>
        </div>

        <!-- Tab content -->
        <div class="tab-content" id="filePickerTabContent">
          <div class="tab-pane fade show active" id="tabpane-www" role="tabpanel">
            <div class="file-tree" id="fileTree-www"></div>
          </div>
          <div class="tab-pane fade" id="tabpane-pluginPages" role="tabpanel">
            <div class="file-tree" id="fileTree-pluginPages"></div>
          </div>
          <div class="tab-pane fade" id="tabpane-admin" role="tabpanel">
            <div class="file-tree" id="fileTree-admin"></div>
          </div>
        </div>

        <!-- Selection summary -->
        <div id="filePickerSummary" class="mt-3 p-3 border rounded bg-light" style="display: none;">
          <div class="mb-2">
            <label class="form-label small fw-bold mb-1">File:</label>
            <span id="filePickerSelectedPath" class="text-muted"></span>
          </div>
          <div class="mb-2">
            <label class="form-label small fw-bold mb-1" for="filePickerLabel">Label:</label>
            <input type="text" class="form-control form-control-sm" id="filePickerLabel" placeholder="Label">
          </div>
          <div class="mb-0">
            <label class="form-label small fw-bold mb-1">href:</label>
            <span id="filePickerHref" class="text-muted font-monospace small"></span>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= __({it: 'Annulla', en: 'Cancel'}, passData.ctx) %></button>
        <button type="button" class="btn btn-primary btn-sm" id="btnFilePickerConfirm" disabled>
          <i class="bi bi-plus"></i> <%= __({it: 'Aggiungi Item', en: 'Add Item'}, passData.ctx) %>
        </button>
      </div>
    </div>
  </div>
</div>

<script src="/<%= passData.adminPrefix %>/navbarsManagement/editor.js"></script>

<%- include( passData.themeSys.getThemePartPath( 'footer.ejs', passData ) ) %>
