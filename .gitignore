node_modules/
.env

# Certificati TLS (mai committare chiavi private)
/certs/

# Auto-generated symlinks (recreated at startup by pluginPagesSystem)
/pluginPages/

# Admin plugin section symlinks (recreated at startup by symlinkManager)
# When adding a new admin plugin, add its sectionId(s) here
/core/admin/webPages/usersManagment
/core/admin/webPages/rolesManagment
/core/admin/webPages/adminAccessControl
/core/admin/webPages/navbarsManagement
/core/admin/webPages/seoManagement
/core/admin/webPages/analyticsManagement
/core/admin/webPages/analyticsSettings
/core/admin/webPages/mediaManagement

# Auto-generated runtime data
/plugins/urlRedirect/redirectHitCount.json5
/plugins/analytics/data/

# SEO plugin generated files (recreated at startup)
/www/sitemap.xml
/www/robots.txt

# Init system
/scripts/initState.json5
/plugins/*/scripts/initState.json5
/logs/
/backups/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
