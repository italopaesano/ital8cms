node_modules/
.env

# VSCode editor settings (user-specific, not part of the repo)
.vscode/

# Certificati TLS (mai committare chiavi private)
/certs/

# Auto-generated symlinks (recreated at startup by pluginPagesSystem)
/pluginPages/

# Admin plugin section symlinks (recreated at startup by symlinkManager)
# When adding a new admin plugin, add its sectionId(s) here
/core/admin/webPages/usersManagment
/core/admin/webPages/rolesManagment
/core/admin/webPages/adminAccessControl
/core/admin/webPages/navbarsManagement
/core/admin/webPages/seoManagement
/core/admin/webPages/analyticsManagement
/core/admin/webPages/analyticsSettings
/core/admin/webPages/mediaManagement
/core/admin/webPages/rateLimiterManagement
/core/admin/webPages/csrfManagement

# Auto-generated runtime data
/plugins/urlRedirect/redirectHitCount.json5
/plugins/analytics/data/
/plugins/admin/themeInstallLog.json5
/plugins/admin/pluginInstallLog.json5

# Config-lifecycle (docs/decisions/config-lifecycle.it.md): config "vivi"
# materializzati dai rispettivi *.default.json5 al boot (materializeMissingConfigs).
# I .default sono committati (fonte di verità); i vivi NO — sono rigenerabili e
# per-istanza (dati utente inclusi). Il boot scrive isInstalled nei descrittori
# vivi (Fase 2), perciò anch'essi NON sono committati. Restano tracciati solo i
# config core (ital8Config/adminConfig/koaSession), legati al gate di init (Fase 3).
/plugins/seo/seoPages.json5
/plugins/urlRedirect/redirectMap.json5
/plugins/adminAccessControl/accessControl.json5
/plugins/rateLimiter/protectedRoutes.json5
/plugins/adminUsers/userAccount.json5
/plugins/adminUsers/userRole.json5
# Descrittori vivi: generati dai .default; isInstalled (stato runtime) scritto al boot.
/plugins/*/pluginConfig.json5
/themes/*/themeConfig.json5

# dbApi: file di database SQLite generati a runtime (plugin opzionale, disattivo di default)
/plugins/dbApi/dbFile/*.db
/plugins/dbApi/dbFile/pluginsDb/*.db

# Public web root (user site content): keep the folder, ignore everything inside.
# Covers site pages and runtime-generated files (e.g. SEO plugin's sitemap.xml / robots.txt).
/www/*
!/www/.gitkeep

# Init system
/scripts/initState.json5
/plugins/*/scripts/initState.json5
/logs/
/backups/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Jest coverage output
/coverage/

# CLI control plane unix socket (created at startup, removed on shutdown)
*.sock
