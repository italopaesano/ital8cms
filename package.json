{
  "name": "ital8cms",
  "version": "0.0.1-alpha.3",
  "description": "Modular, plugin-based CMS built on Node.js and Koa.js (file-based storage, zero database by default)",
  "main": "index.js",
  "bin": {
    "ital8cms-cli": "./bin/ital8cms-cli.js"
  },
  "scripts": {
    "start-configure": "node scripts/init.js",
    "start": "nodemon index.js",
    "cli": "node bin/ital8cms-cli.js",
    "test": "node scripts/checkNixShell.js && jest --config=tests/jest.config.js && npx playwright test --config=tests/playwright.config.js",
    "test:watch": "jest --config=tests/jest.config.js --watch",
    "test:coverage": "jest --config=tests/jest.config.js --coverage",
    "test:unit": "jest --config=tests/jest.config.js --testPathPatterns=tests/unit",
    "test:integration": "jest --config=tests/jest.config.js --testPathPatterns=tests/integration",
    "test:plugin": "node scripts/checkNixShell.js && node scripts/testRunner.js --plugin=$npm_config_plugin",
    "test:themes": "node scripts/checkNixShell.js && node scripts/testRunner.js --themes",
    "test:core": "node scripts/checkNixShell.js && node scripts/testRunner.js --core",
    "test:e2e": "node scripts/checkNixShell.js && npx playwright test --config=tests/playwright.config.js",
    "test:e2e:ui": "node scripts/checkNixShell.js && npx playwright test --config=tests/playwright.config.js --ui",
    "test:e2e:headed": "node scripts/checkNixShell.js && npx playwright test --config=tests/playwright.config.js --headed",
    "test:e2e:debug": "node scripts/checkNixShell.js && npx playwright test --config=tests/playwright.config.js --debug",
    "test:e2e:prefix": "node scripts/checkNixShell.js && npx playwright test --config=tests/playwright.globalPrefix.config.js",
    "test:e2e:report": "npx playwright show-report",
    "test:all": "npm run test && npm run test:e2e && npm run test:e2e:prefix"
  },
  "author": "Italo Paesano <italopaesano@protonmail.com> (https://github.com/italopaesano)",
  "license": "ISC",
  "dependencies": {
    "@koa/multer": "^4.0.0",
    "@koa/router": "^15.5.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "ccxt": "^4.1.70",
    "chart.js": "^4.5.1",
    "commander": "^15.0.0",
    "ejs": "^6.0.1",
    "handlebars": "^4.7.9",
    "inquirer": "^8.2.7",
    "json5": "^2.2.3",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.4.1",
    "koa-classic-server": "^3.0.0",
    "koa-session": "^7.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.0",
    "nodemon": "^3.1.14",
    "semver": "^7.8.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2"
  }
}
